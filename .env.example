NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@db:5432/desi_events
JWT_SECRET=change-me

# Frontend/backend connection
FRONTEND_URL=http://localhost:5173
PUBLIC_FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:4000
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_change_me

# Stripe payments
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_PUBLISHABLE_KEY=pk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
CURRENCY=gbp

# Production safety
# Set this to false in live production so paid tickets cannot be issued through the dev/test button.
ALLOW_TEST_PAYMENTS=true
PENDING_ORDER_TTL_MS=1800000

# Ticket email delivery (v68)
# Recommended production provider:
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=LocalVibe Tickets <tickets@yourdomain.com>
EMAIL_REPLY_TO=support@yourdomain.com
EMAIL_TEST_TO=

# SMTP is detected but direct SMTP sending is reserved for later nodemailer wiring.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=
