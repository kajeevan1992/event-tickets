generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

enum UserRole { USER ORGANISER ADMIN }
enum EventStatus { DRAFT PENDING PUBLISHED REJECTED CANCELLED }
enum TicketStatus { ACTIVE USED CANCELLED REFUNDED }
enum SponsorshipStatus { NEW CONTACTED IN_DISCUSSION WAITING_FOR_ORGANISER WON LOST }

model User { id String @id @default(cuid()) email String @unique name String? passwordHash String? role UserRole @default(USER) createdAt DateTime @default(now()) organiser Organiser? orders Order[] savedEvents SavedEvent[] }
model Organiser { id String @id @default(cuid()) userId String @unique displayName String bio String? verified Boolean @default(false) user User @relation(fields:[userId], references:[id]) events Event[] }
model City { id String @id @default(cuid()) name String @unique events Event[] }
model Category { id String @id @default(cuid()) name String @unique slug String @unique events Event[] }
model Tag { id String @id @default(cuid()) name String @unique slug String @unique events EventTag[] }
model Event { id String @id @default(cuid()) organiserId String title String slug String @unique description String? posterUrl String? cityId String categoryId String status EventStatus @default(PENDING) venueName String? startsAt DateTime endsAt DateTime? isHiddenGem Boolean @default(false) localBoostScore Int @default(0) organiser Organiser @relation(fields:[organiserId], references:[id]) city City @relation(fields:[cityId], references:[id]) category Category @relation(fields:[categoryId], references:[id]) ticketTypes TicketType[] orders Order[] tags EventTag[] savedBy SavedEvent[] sponsorships SponsorshipEnquiry[] createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model TicketType { id String @id @default(cuid()) eventId String name String priceMinor Int currency String @default("GBP") capacity Int? sold Int @default(0) event Event @relation(fields:[eventId], references:[id]) orderItems OrderItem[] }
model Order { id String @id @default(cuid()) userId String? eventId String buyerName String buyerEmail String totalMinor Int currency String @default("GBP") stripePaymentIntentId String? status String @default("pending") user User? @relation(fields:[userId], references:[id]) event Event @relation(fields:[eventId], references:[id]) items OrderItem[] tickets Ticket[] createdAt DateTime @default(now()) }
model OrderItem { id String @id @default(cuid()) orderId String ticketTypeId String quantity Int unitPriceMinor Int order Order @relation(fields:[orderId], references:[id]) ticketType TicketType @relation(fields:[ticketTypeId], references:[id]) }
model Ticket { id String @id @default(cuid()) orderId String qrCode String @unique attendeeName String? attendeeEmail String? status TicketStatus @default(ACTIVE) order Order @relation(fields:[orderId], references:[id]) checkins TicketCheckin[] }
model TicketCheckin { id String @id @default(cuid()) ticketId String checkedInAt DateTime @default(now()) checkedByUserId String? ticket Ticket @relation(fields:[ticketId], references:[id]) }
model SavedEvent { userId String eventId String createdAt DateTime @default(now()) user User @relation(fields:[userId], references:[id]) event Event @relation(fields:[eventId], references:[id]) @@id([userId,eventId]) }
model EventTag { eventId String tagId String event Event @relation(fields:[eventId], references:[id]) tag Tag @relation(fields:[tagId], references:[id]) @@id([eventId,tagId]) }
model SponsorshipEnquiry { id String @id @default(cuid()) eventId String companyName String contactName String email String phone String? budgetMinor Int? sponsorshipType String? message String? status SponsorshipStatus @default(NEW) adminNotes String? event Event @relation(fields:[eventId], references:[id]) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model PromoCode { id String @id @default(cuid()) code String @unique discountPercent Int? discountMinor Int? active Boolean @default(true) }
