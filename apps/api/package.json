{
  "name": "@desi-events/api",
  "private": true,
  "version": "1.0.4",
  "type": "module",
  "scripts": {
    "dev": "prisma generate && node --watch --import ./src/referral-autoload.js src/server.js",
    "build": "prisma generate && node -e \"console.log('api build ok')\"",
    "start": "node --import ./src/referral-autoload.js src/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:setup": "prisma generate && prisma db push && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "6.16.3",
    "prisma": "6.16.3",
    "express": "latest",
    "cors": "latest",
    "helmet": "latest",
    "morgan": "latest",
    "jsonwebtoken": "latest",
    "bcryptjs": "latest",
    "qrcode": "latest",
    "stripe": "latest",
    "zod": "latest"
  }
}
